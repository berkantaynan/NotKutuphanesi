<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="#F8F9FA"
    tools:context=".HomeActivity">

    <TextView
        android:id="@+id/tvWelcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ortak Ders Havuzu"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#2196F3"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp"/>

    <Button
        android:id="@+id/btnLogout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Çıkış"
        android:backgroundTint="#F44336"
        app:layout_constraintTop_toTopOf="@id/tvWelcome"
        app:layout_constraintBottom_toBottomOf="@id/tvWelcome"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Spinner
        android:id="@+id/spinnerCourses"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvWelcome"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <EditText
        android:id="@+id/etNewNote"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:hint="Kısa açıklama yaz..."
        android:background="#FFFFFF"
        android:padding="12dp"
        android:elevation="2dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/spinnerCourses"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <EditText
        android:id="@+id/etNoteLink"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:hint="Dosya/PDF Linki (Opsiyonel)"
        android:background="#FFFFFF"
        android:padding="12dp"
        android:elevation="2dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/etNewNote"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnAddNote"
        android:layout_marginEnd="8dp"/>

    <Button
        android:id="@+id/btnAddNote"
        android:layout_width="wrap_content"
        android:layout_height="55dp"
        android:text="PAYLAŞ"
        android:backgroundTint="#4CAF50"
        app:layout_constraintTop_toTopOf="@id/etNoteLink"
        app:layout_constraintBottom_toBottomOf="@id/etNoteLink"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ListView
        android:id="@+id/listViewNotes"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/etNoteLink"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>